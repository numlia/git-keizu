{
  "compilerOptions": {
    "lib": ["es2020", "dom"],
    "module": "es2020",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "strict": true,
    "target": "es2020"
  }
}
