{
  "name": "git-keizu",
  "displayName": "Git Keizu",
  "version": "0.8.2",
  "description": "Git history graph / 日本語UI対応 — checkout, merge, rebase, cherry-pick, stash & worktree. Successor to Git Graph. Requires Git 2.32+.",
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "keywords": [
    "branch",
    "cherry-pick",
    "commit",
    "git",
    "git graph",
    "git history",
    "git log",
    "git tree",
    "git viewer",
    "graph",
    "history",
    "japanese",
    "merge",
    "rebase",
    "scm",
    "stash",
    "tag",
    "version control",
    "visualize",
    "日本語"
  ],
  "homepage": "https://github.com/numlia/git-keizu",
  "bugs": {
    "url": "https://github.com/numlia/git-keizu/issues"
  },
  "license": "MIT",
  "author": {
    "name": "numlia",
    "email": "43361508+numlia@users.noreply.github.com"
  },
  "contributors": [
    {
      "name": "Michael Hutchison",
      "url": "https://github.com/mhutchie"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/numlia/git-keizu.git"
  },
  "publisher": "numlia-vs",
  "main": "./out/extension.js",
  "scripts": {
    "typecheck": "tsc -p ./src --noEmit && tsc -p ./web --noEmit",
    "vscode:prepublish": "npx --yes pnpm@10.29.3 run compile",
    "clean": "rm -rf out",
    "copy-codicons": "cp node_modules/@vscode/codicons/dist/codicon.css media/codicon.css && cp node_modules/@vscode/codicons/dist/codicon.ttf media/codicon.ttf",
    "compile": "pnpm run clean && pnpm run copy-codicons && pnpm run compile-src && pnpm run compile-web",
    "compile-src": "esbuild --bundle src/extension.ts --outfile=out/extension.js --platform=node --format=cjs --target=es6 --external:vscode --minify",
    "compile-web": "esbuild --bundle web/main.ts --outfile=out/web.min.js --minify --target=es2020 --format=iife",
    "package": "pnpm run clean && vsce package",
    "package-and-install": "pnpm run clean && vsce package && node ./.vscode/install-package.js",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/vscode": "~1.74.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "category": "%command.category%",
        "command": "git-keizu.view",
        "title": "%command.view.title%",
        "icon": {
          "light": "resources/cmd-icon-light.svg",
          "dark": "resources/cmd-icon-dark.svg"
        }
      },
      {
        "category": "%command.category%",
        "command": "git-keizu.clearAvatarCache",
        "title": "%command.clearAvatarCache.title%"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "git-keizu.view",
          "when": "scmProvider == git && config.git-keizu.sourceCodeProviderIntegrationLocation == 'Inline'",
          "group": "navigation"
        },
        {
          "command": "git-keizu.view",
          "when": "scmProvider == git && config.git-keizu.sourceCodeProviderIntegrationLocation == 'More Actions'"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "%config.title%",
      "properties": {
        "git-keizu.dateFormat": {
          "type": "string",
          "enum": [
            "Date & Time",
            "Date Only",
            "Relative"
          ],
          "enumDescriptions": [
            "%config.dateFormat.enum.dateAndTime%",
            "%config.dateFormat.enum.dateOnly%",
            "%config.dateFormat.enum.relative%"
          ],
          "default": "Date & Time",
          "description": "%config.dateFormat.description%"
        },
        "git-keizu.dateType": {
          "type": "string",
          "enum": [
            "Author Date",
            "Commit Date"
          ],
          "enumDescriptions": [
            "%config.dateType.enum.authorDate%",
            "%config.dateType.enum.commitDate%"
          ],
          "default": "Author Date",
          "description": "%config.dateType.description%"
        },
        "git-keizu.fetchAvatars": {
          "type": "boolean",
          "default": false,
          "description": "%config.fetchAvatars.description%"
        },
        "git-keizu.graphColours": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "%config.graphColours.item.description%",
            "pattern": "^\\s*(#[0-9a-fA-F]{6}|#[0-9a-fA-F]{8}|rgb\\s*\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*\\)|rgba\\s*\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*(0(\\.\\d+)?|1(\\.0+)?)\\s*\\))\\s*$"
          },
          "default": [
            "#0085d9",
            "#d9008f",
            "#00d90a",
            "#d98500",
            "#a300d9",
            "#ff0000",
            "#00d9cc",
            "#e138e8",
            "#85d900",
            "#dc5b23",
            "#6f24d6",
            "#ffcc00"
          ],
          "description": "%config.graphColours.description%"
        },
        "git-keizu.graphStyle": {
          "type": "string",
          "enum": [
            "rounded",
            "angular"
          ],
          "enumDescriptions": [
            "%config.graphStyle.enum.rounded%",
            "%config.graphStyle.enum.angular%"
          ],
          "default": "rounded",
          "description": "%config.graphStyle.description%"
        },
        "git-keizu.initialLoadCommits": {
          "type": "number",
          "default": 300,
          "minimum": 1,
          "description": "%config.initialLoadCommits.description%"
        },
        "git-keizu.loadMoreCommits": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "%config.loadMoreCommits.description%"
        },
        "git-keizu.maxDepthOfRepoSearch": {
          "type": "number",
          "default": 0,
          "description": "%config.maxDepthOfRepoSearch.description%"
        },
        "git-keizu.showCurrentBranchByDefault": {
          "type": "boolean",
          "default": false,
          "description": "%config.showCurrentBranchByDefault.description%"
        },
        "git-keizu.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "%config.showStatusBarItem.description%"
        },
        "git-keizu.showUncommittedChanges": {
          "type": "boolean",
          "default": true,
          "description": "%config.showUncommittedChanges.description%"
        },
        "git-keizu.tabIconColourTheme": {
          "type": "string",
          "enum": [
            "colour",
            "grey"
          ],
          "enumDescriptions": [
            "%config.tabIconColourTheme.enum.colour%",
            "%config.tabIconColourTheme.enum.grey%"
          ],
          "default": "colour",
          "description": "%config.tabIconColourTheme.description%"
        },
        "git-keizu.sourceCodeProviderIntegrationLocation": {
          "type": "string",
          "enum": [
            "Inline",
            "More Actions"
          ],
          "enumDescriptions": [
            "%config.sourceCodeProviderIntegrationLocation.enum.inline%",
            "%config.sourceCodeProviderIntegrationLocation.enum.moreActions%"
          ],
          "default": "Inline",
          "description": "%config.sourceCodeProviderIntegrationLocation.description%"
        },
        "git-keizu.keyboardShortcutFind": {
          "type": "string",
          "default": "CTRL/CMD + F",
          "description": "%config.keyboardShortcutFind.description%"
        },
        "git-keizu.keyboardShortcutRefresh": {
          "type": "string",
          "default": "CTRL/CMD + R",
          "description": "%config.keyboardShortcutRefresh.description%"
        },
        "git-keizu.keyboardShortcutScrollToHead": {
          "type": "string",
          "default": "CTRL/CMD + H",
          "description": "%config.keyboardShortcutScrollToHead.description%"
        },
        "git-keizu.keyboardShortcutScrollToStash": {
          "type": "string",
          "default": "CTRL/CMD + S",
          "description": "%config.keyboardShortcutScrollToStash.description%"
        },
        "git-keizu.loadMoreCommitsAutomatically": {
          "type": "boolean",
          "default": true,
          "description": "%config.loadMoreCommitsAutomatically.description%"
        },
        "git-keizu.menu.showRecentActions": {
          "type": "boolean",
          "default": true,
          "description": "%config.menu.showRecentActions.description%"
        },
        "git-keizu.dialog.merge.noFastForward": {
          "type": "boolean",
          "default": true,
          "description": "%config.dialog.merge.noFastForward.description%"
        },
        "git-keizu.dialog.merge.squashCommits": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.merge.squashCommits.description%"
        },
        "git-keizu.dialog.merge.noCommit": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.merge.noCommit.description%"
        },
        "git-keizu.dialog.cherryPick.noCommit": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.cherryPick.noCommit.description%"
        },
        "git-keizu.dialog.cherryPick.recordOrigin": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.cherryPick.recordOrigin.description%"
        },
        "git-keizu.dialog.stashUncommittedChanges.includeUntracked": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.stashUncommittedChanges.includeUntracked.description%"
        },
        "git-keizu.dialog.createWorktree.openTerminal": {
          "type": "boolean",
          "default": true,
          "description": "%config.dialog.createWorktree.openTerminal.description%"
        },
        "git-keizu.dialog.removeWorktree.deleteBranch": {
          "type": "boolean",
          "default": true,
          "description": "%config.dialog.removeWorktree.deleteBranch.description%"
        },
        "git-keizu.repository.commits.order": {
          "type": "string",
          "enum": [
            "date",
            "topo",
            "author-date"
          ],
          "enumDescriptions": [
            "%config.repository.commits.order.enum.date%",
            "%config.repository.commits.order.enum.topo%",
            "%config.repository.commits.order.enum.authorDate%"
          ],
          "default": "date",
          "description": "%config.repository.commits.order.description%"
        },
        "git-keizu.repository.commits.mute.mergeCommits": {
          "type": "boolean",
          "default": true,
          "description": "%config.repository.commits.mute.mergeCommits.description%"
        },
        "git-keizu.repository.commits.mute.commitsThatAreNotAncestorsOfHead": {
          "type": "boolean",
          "default": false,
          "description": "%config.repository.commits.mute.commitsThatAreNotAncestorsOfHead.description%"
        },
        "git-keizu.openNewTabEditorGroup": {
          "type": "string",
          "enum": [
            "Active",
            "Beside",
            "One",
            "Two",
            "Three",
            "Four",
            "Five",
            "Six",
            "Seven",
            "Eight",
            "Nine"
          ],
          "default": "Active",
          "description": "%config.openNewTabEditorGroup.description%"
        }
      }
    }
  },
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "packageManager": "pnpm@10.29.3"
}
